# Voice Analysis and Intervention System - Environment Configuration

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=voice_analysis
MONGODB_ENCRYPTION_KEY_FILE=/path/to/keyfile

# Audio Processor Configuration
AUDIO_PROCESSOR_HOST=0.0.0.0
AUDIO_PROCESSOR_PORT=8000
AUDIO_PROCESSOR_MAX_CONCURRENT_USERS=10

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:8001
GEMMA4_MODEL_PATH=/path/to/gemma4/model

# Security Configuration
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=1
ANONYMIZATION_SALT=your-salt-here

# TLS Configuration
TLS_CERT_FILE=/path/to/server.crt
TLS_KEY_FILE=/path/to/server.key
TLS_CA_FILE=/path/to/ca.crt

# Performance Configuration
PROCESSING_TIMEOUT_SECONDS=5
LINGUISTIC_TIMEOUT_SECONDS=3
INSIGHT_TIMEOUT_SECONDS=5
INTERVENTION_TIMEOUT_SECONDS=5
BASELINE_TIMEOUT_SECONDS=1
TELEMETRY_TIMEOUT_SECONDS=1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Model Versions
SENSEVOICE_VERSION=1.0.0
WAV2VEC2_VERSION=1.0.0
GEMMA4_VERSION=1.0.0
